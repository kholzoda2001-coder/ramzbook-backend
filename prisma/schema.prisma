generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  email             String?   @unique
  phone             String?   @unique
  passwordHash      String
  name              String
  avatarUrl         String?
  isActive          Boolean   @default(true)
  nativeLang        String    @default("tg") // UI / interface language code
  interfaceLang     String    @default("tg")
  targetLang        String?   // currently-learning language code
  
  // Stats
  totalXp           Int       @default(0)
  weeklyXp          Int       @default(0)
  gems              Int       @default(0)
  level             String    @default("A1")
  currentCourseId   String?
  
  // Hearts
  hearts            Int       @default(5)
  maxHearts         Int       @default(5)
  lastHeartRegen    DateTime  @default(now())
  
  // Streak
  streak            Int       @default(0)
  longestStreak     Int       @default(0)
  lastActiveDate    DateTime?
  streakFreezesAvailable Int  @default(1)
  streakFreezesUsed Int       @default(0)
  
  // Premium (legacy fields — kept for the Google Play webhook flow)
  isPremium         Boolean   @default(false)
  premiumPlan       String?   // "monthly" | "yearly" | "lifetime"
  premiumStartedAt  DateTime?
  premiumExpiresAt  DateTime?
  trialUsed         Boolean   @default(false)
  trialStartedAt    DateTime?

  // Freemium subscription system (canonical going forward)
  subscriptionTier   String    @default("free") // free | premium
  subscriptionPlan   String?   // monthly | yearly
  trialEndsAt        DateTime?
  subscriptionEndsAt DateTime?
  
  // AI Tutor
  aiConversationsToday Int    @default(0)
  aiConversationsResetAt DateTime @default(now())
  
  // Misc
  createdAt         DateTime  @default(now())
  lastActiveAt      DateTime  @default(now())
  
  // Relations
  progress          UserProgress[]
  achievements      UserAchievement[]
  subscriptions     Subscription[]
  payments          Payment[]
  gemTransactions   GemTransaction[]
  userLanguages     UserLanguage[]
  refreshTokens     RefreshToken[]
  dailyXp           DailyXp[]
  promoRedemptions  PromoRedemption[]
  paymentTransactions PaymentTransaction[]
  paywallEvents     PaywallEvent[]
  srsCards          SrsCard[]

  @@index([email])
  @@index([phone])
  @@index([isPremium])
  @@index([subscriptionTier])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Language {
  id                String   @id @default(cuid())
  code              String   @unique // en, ru, tr, etc
  name              String              // English exonym, e.g. "Tajik"
  nativeName        String              // endonym, e.g. "Тоҷикӣ"
  flag              String              // emoji flag
  canBeNative       Boolean  @default(false) // usable as UI / interface language
  canBeTarget       Boolean  @default(true)  // usable as a learnable language
  badge             String?             // HOT | LIVE | SOON
  learnerCount      String?             // "1.5B learners"
  order             Int      @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  // ── Language-agnostic runtime config (driven from admin, NOT code) ──
  // Adding a new language requires only these DB fields — no app changes.
  ttsLocale         String?             // BCP-47 for text-to-speech, e.g. "en-US", "ar-SA"
  sttLocale         String?             // BCP-47 for speech-to-text (often == ttsLocale)
  direction         String   @default("ltr") // "ltr" | "rtl" (Arabic, Hebrew, Farsi → rtl)
  fontFamily        String?             // optional custom font, e.g. "Noto Sans Arabic"
  hasIPA            Boolean  @default(true)   // show phonetic transcription for this language
  exerciseConfig    Json?               // which exercise types are enabled for this language

  coursesAsTarget   Course[]        @relation("TargetLang")
  coursesAsNative   Course[]        @relation("NativeLang")
  uiTranslations    UiTranslation[]
  userLanguages     UserLanguage[]
  cefrDescriptorsAsTarget CefrDescriptor[] @relation("DescriptorTarget")
  cefrDescriptorsAsNative CefrDescriptor[] @relation("DescriptorNative")
  placementAsTarget PlacementQuestion[] @relation("PlacementTarget")
  placementAsNative PlacementQuestion[] @relation("PlacementNative")
}

model UserLanguage {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  languageId        String
  language          Language @relation(fields: [languageId], references: [id])
  
  fromLang          String   // tg, ru, etc
  currentLevel      String   @default("A1")
  xp                Int      @default(0)
  streak            Int      @default(0)
  isCurrent         Boolean  @default(false)
  goal              String?  // travel, work, study, social, culture, tech
  startedAt         DateTime @default(now())
  
  @@unique([userId, languageId])
  @@index([userId])
}

model Course {
  id                String   @id @default(cuid())
  // A course is bound to a (target, native) language PAIR.
  targetLanguageId  String
  targetLanguage    Language @relation("TargetLang", fields: [targetLanguageId], references: [id])
  nativeLanguageId  String
  nativeLanguage    Language @relation("NativeLang", fields: [nativeLanguageId], references: [id])
  level             String   // A1, A2, B1, B2, C1
  title             String              // shown in native language
  description       String?
  emoji             String
  color             String   // hex color
  order             Int      @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  modules           Module[]
  grammarTopics     GrammarTopic[]
  phraseCollections PhraseCollection[]
  dialogues         Dialogue[]
  comprehensions    ComprehensionExercise[]

  @@unique([targetLanguageId, nativeLanguageId, level])
  @@index([targetLanguageId])
  @@index([nativeLanguageId])
}

model Module {
  id                String   @id @default(cuid())
  courseId          String
  course            Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title             String              // target-language title, e.g. "Foundations"
  titleTranslated   String              // native-language title, e.g. "Асосҳо"
  emoji             String
  color             String   @default("#10B981")
  order             Int      @default(0)
  isPremium         Boolean  @default(false) // requires Premium
  isBoss            Boolean  @default(false) // boss module
  isActive          Boolean  @default(true)

  lessons           Lesson[]

  @@index([courseId])
}

model Lesson {
  id                String   @id @default(cuid())
  moduleId          String
  module            Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title             String              // target-language title, e.g. "Greetings"
  titleTranslated   String              // native-language title, e.g. "Саломҳо"
  type              String   @default("vocab") // "vocab" | "quiz" (legacy display tag)
  // ── CEFR framework (Step 2) ──
  cefrLevel         String?             // A1…C2 — falls back to the course level if null
  skillType         String   @default("vocab") // vocab|grammar|reading|listening|speaking|writing|review|test
  emoji             String
  xpReward          Int      @default(60)
  duration          Int      @default(5) // minutes
  order             Int      @default(0)
  isPremium         Boolean  @default(false)
  isActive          Boolean  @default(true)
  // ── Unified path (Step 11): a lesson is one step in the sequence; by skillType
  // it may link to any one component, which the player renders inline ──
  grammarTopicId    String?
  grammarTopic      GrammarTopic? @relation(fields: [grammarTopicId], references: [id], onDelete: SetNull)
  phraseCollectionId String?
  phraseCollection  PhraseCollection? @relation(fields: [phraseCollectionId], references: [id], onDelete: SetNull)
  dialogueId        String?
  dialogue          Dialogue? @relation(fields: [dialogueId], references: [id], onDelete: SetNull)
  comprehensionId   String?
  comprehension     ComprehensionExercise? @relation(fields: [comprehensionId], references: [id], onDelete: SetNull)

  words             Word[]
  progress          UserProgress[]

  @@index([moduleId])
  @@index([grammarTopicId])
  @@index([phraseCollectionId])
  @@index([dialogueId])
  @@index([comprehensionId])
}

model Word {
  id                String   @id @default(cuid())
  lessonId          String
  lesson            Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  word              String              // target-language word, e.g. "Hello"
  translation       String              // native-language translation, e.g. "Салом"
  emoji             String?
  ipa               String?             // /həˈloʊ/
  example           String?             // target-language example sentence
  exampleTrans      String?             // native-language translation of the example
  audioUrl          String?
  difficulty        Int      @default(1) // 1-5
  // ── CEFR framework (Step 2) ──
  partOfSpeech      String?             // noun|verb|adjective|adverb|phrase|… (language-agnostic tag)
  frequencyRank     Int?                // lower = more frequent → learn earlier
  order             Int      @default(0)

  @@index([lessonId])
}

// CEFR "can-do" descriptor — the measurable target per (target,native) pair + level.
// Language-agnostic: defined entirely from the admin panel, never hardcoded.
model CefrDescriptor {
  id                String   @id @default(cuid())
  targetLanguageId  String
  targetLanguage    Language @relation("DescriptorTarget", fields: [targetLanguageId], references: [id], onDelete: Cascade)
  nativeLanguageId  String
  nativeLanguage    Language @relation("DescriptorNative", fields: [nativeLanguageId], references: [id], onDelete: Cascade)
  cefrLevel         String   // A1…C2
  skill             String   @default("overall") // overall|reading|writing|listening|speaking
  canDo             String   @db.Text            // "can-do" statement shown in the native language
  order             Int      @default(0)
  createdAt         DateTime @default(now())

  @@index([targetLanguageId, nativeLanguageId, cefrLevel])
}

// ── Placement test (Phase 5) — language-agnostic, admin-driven ──
// A placement question belongs to a (target, native) language PAIR, NOT a single
// course, because a placement test spans MULTIPLE CEFR levels. Each question is
// tagged with the level it probes; the scoring engine infers the learner's level
// from which levels they answer correctly. Multiple-choice so it auto-grades
// (no human evaluation needed). Nothing here is hardcoded per language.
model PlacementQuestion {
  id                String   @id @default(cuid())
  targetLanguageId  String
  targetLanguage    Language @relation("PlacementTarget", fields: [targetLanguageId], references: [id], onDelete: Cascade)
  nativeLanguageId  String
  nativeLanguage    Language @relation("PlacementNative", fields: [nativeLanguageId], references: [id], onDelete: Cascade)
  cefrLevel         String              // A1…C2 — the level this question probes
  skill             String   @default("overall") // overall|reading|writing|listening|speaking|grammar|vocab
  prompt            String   @db.Text   // the question (usually target language)
  promptTranslated  String?  @db.Text   // native-language hint/translation
  options           Json                // string[] of answer options
  answer            String   @db.Text   // the correct option (must equal one of options)
  explanation       String?  @db.Text   // native-language reason shown after answering
  audioUrl          String?             // for listening-type placement items
  order             Int      @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  @@index([targetLanguageId, nativeLanguageId, cefrLevel])
  @@index([targetLanguageId, nativeLanguageId, isActive])
}

// ── Grammar system (Step 3) — language-agnostic, admin-driven ──
// A grammar topic belongs to a course (so it inherits the target/native pair).
model GrammarTopic {
  id                String   @id @default(cuid())
  courseId          String
  course            Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  cefrLevel         String?             // A1…C2 — falls back to the course level if null
  title             String              // target-language title, e.g. "Present Simple"
  titleTranslated   String              // native-language title, e.g. "Замони ҳозираи содда"
  explanation       String   @db.Text   // Markdown explanation, written in the native language
  emoji             String   @default("🔤")
  order             Int      @default(0)
  isPremium         Boolean  @default(false)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  examples          GrammarExample[]
  rules             GrammarRule[]
  exercises         GrammarExercise[]
  lessons           Lesson[]            // lessons that teach this topic

  @@index([courseId])
}

model GrammarExample {
  id                String   @id @default(cuid())
  topicId           String
  topic             GrammarTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  sentence          String              // target-language example sentence
  translation       String              // native-language translation
  audioUrl          String?
  highlight         String?             // substring of `sentence` to emphasise (e.g. the conjugated verb)
  order             Int      @default(0)

  @@index([topicId])
}

model GrammarRule {
  id                String   @id @default(cuid())
  topicId           String
  topic             GrammarTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  pattern           String              // e.g. "Subject + do/does + base verb"
  note              String?  @db.Text   // native-language note explaining the rule
  order             Int      @default(0)

  @@index([topicId])
}

model GrammarExercise {
  id                String   @id @default(cuid())
  topicId           String
  topic             GrammarTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  type              String   @default("fill_blank") // fill_blank | choose | reorder | transform
  prompt            String   @db.Text   // the question (target language, may contain "___")
  promptTranslated  String?  @db.Text   // native-language hint/translation
  answer            String              // the correct answer
  options           Json?               // string[] of options for "choose" / "reorder" types
  explanation       String?  @db.Text   // native-language reason the answer is correct
  order             Int      @default(0)

  @@index([topicId])
}

// ── Sentence / Phrase bank (Step 5) — language-agnostic, admin-driven ──
// A phrase collection belongs to a course (inherits the target/native pair).
// Used for teaching ready-made useful sentences/phrases (greetings, travel…),
// each with target text, native translation, optional literal gloss + audio.
model PhraseCollection {
  id                String   @id @default(cuid())
  courseId          String
  course            Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  cefrLevel         String?             // A1…C2 — falls back to the course level if null
  category          String?             // free language-agnostic tag, e.g. "greetings", "travel"
  title             String              // target-language title, e.g. "At the Restaurant"
  titleTranslated   String              // native-language title, e.g. "Дар тарабхона"
  emoji             String   @default("💬")
  order             Int      @default(0)
  isPremium         Boolean  @default(false)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  phrases           Phrase[]
  lessons           Lesson[]            // lessons that teach this collection

  @@index([courseId])
}

model Phrase {
  id                String   @id @default(cuid())
  collectionId      String
  collection        PhraseCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  text              String   @db.Text   // target-language phrase/sentence
  translation       String   @db.Text   // native-language translation
  literal           String?  @db.Text   // optional word-by-word / literal gloss
  note              String?  @db.Text   // native-language usage note
  audioUrl          String?
  order             Int      @default(0)

  @@index([collectionId])
}

// ── Dialogue system (Step 7) — language-agnostic, admin-driven ──
// A dialogue belongs to a course (inherits the target/native pair). It is an
// ordered conversation between two or more speakers, each line with target
// text + native translation + optional audio. `isUser` marks "my" turns.
model Dialogue {
  id                String   @id @default(cuid())
  courseId          String
  course            Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  cefrLevel         String?             // A1…C2 — falls back to the course level if null
  title             String              // target-language title, e.g. "Ordering Coffee"
  titleTranslated   String              // native-language title, e.g. "Фармоиши қаҳва"
  scenario          String?  @db.Text   // native-language setup/description of the situation
  emoji             String   @default("🎙️")
  order             Int      @default(0)
  isPremium         Boolean  @default(false)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  lines             DialogueLine[]
  lessons           Lesson[]            // lessons that play this dialogue

  @@index([courseId])
}

model DialogueLine {
  id                String   @id @default(cuid())
  dialogueId        String
  dialogue          Dialogue @relation(fields: [dialogueId], references: [id], onDelete: Cascade)
  speaker           String              // speaker name/label, e.g. "Barista", "Alex"
  text              String   @db.Text   // target-language line
  translation       String   @db.Text   // native-language translation
  audioUrl          String?
  isUser            Boolean  @default(false) // true → this line belongs to the learner ("me")
  order             Int      @default(0)

  @@index([dialogueId])
}

// Reading/listening comprehension: a passage (or audio transcript) plus
// multiple-choice questions that test understanding. Language-agnostic — the
// passage language is the course's target language; questions/options/native
// hints all come from admin content, never hard-coded.
model ComprehensionExercise {
  id                 String   @id @default(cuid())
  courseId           String
  course             Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  cefrLevel          String?             // A1…C2 — falls back to the course level if null
  kind               String   @default("reading") // reading | listening
  title              String              // target-language title
  titleTranslated    String              // native-language title
  passage            String   @db.Text   // the reading text, or the transcript for a listening clip
  passageTranslated  String?  @db.Text   // optional native-language translation of the passage
  audioUrl           String?             // audio clip URL (used for "listening" kind)
  emoji              String   @default("📖")
  order              Int      @default(0)
  isPremium          Boolean  @default(false)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())

  questions          ComprehensionQuestion[]
  lessons            Lesson[]            // lessons that use this exercise

  @@index([courseId])
}

model ComprehensionQuestion {
  id                 String   @id @default(cuid())
  exerciseId         String
  exercise           ComprehensionExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  question           String   @db.Text   // the question (usually target language)
  questionTranslated String?  @db.Text   // optional native-language version of the question
  options            Json                // string[] of answer choices
  correctIndex       Int      @default(0) // index into options of the correct answer
  explanation        String?  @db.Text   // native-language reason the answer is correct
  order              Int      @default(0)

  @@index([exerciseId])
}

// Spaced-repetition review card (SM-2). One row per (user, item). Item-agnostic
// via (itemType, itemId) so the same engine serves vocabulary, phrases, grammar,
// etc. — never hard-coded to a language. The scheduler stores only the SM-2
// state; the underlying content (word/translation/…) is hydrated at read time.
model SrsCard {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemType       String    @default("word") // word | phrase | grammar | dialogue_line | …
  itemId         String              // id of the underlying content item
  courseId       String?             // lets the review queue be filtered per course
  easeFactor     Float     @default(2.5)   // SM-2 ease (min 1.3)
  intervalDays   Int       @default(0)     // current interval in days
  repetitions    Int       @default(0)     // consecutive correct reviews
  lapses         Int       @default(0)     // times forgotten ("again")
  dueAt          DateTime  @default(now())  // when this card next becomes reviewable
  lastReviewedAt DateTime?
  createdAt      DateTime  @default(now())

  @@unique([userId, itemType, itemId])
  @@index([userId, dueAt])
  @@index([userId, courseId])
}

model UiTranslation {
  id          String   @id @default(cuid())
  languageId  String
  language    Language @relation(fields: [languageId], references: [id], onDelete: Cascade)
  key         String              // "home.title"
  value       String   @db.Text   // "Хона"

  @@unique([languageId, key])
  @@index([languageId])
}

model OtpCode {
  id             String   @id @default(cuid())
  identifier     String              // normalized email or phone
  channel        String              // "email" | "phone"
  otpHash        String              // HMAC-SHA256 of the code
  expiresAt      DateTime
  used           Boolean  @default(false)
  verifyAttempts Int      @default(0)
  createdAt      DateTime @default(now())

  @@index([identifier, createdAt])
  @@index([identifier, used])
}

model AppSetting {
  key       String   @id              // e.g. "login_settings", "auth_providers"
  valueJson String   @db.Text
  updatedAt DateTime @updatedAt
}

model UserProgress {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  lessonId          String
  lesson            Lesson   @relation(fields: [lessonId], references: [id])
  isCompleted       Boolean  @default(false)
  accuracy          Int      @default(0) // percentage
  xpEarned          Int      @default(0)
  timeSpent         Int      @default(0) // seconds
  heartsLost        Int      @default(0)
  completedAt       DateTime?
  
  @@unique([userId, lessonId])
  @@index([userId])
}

model Achievement {
  id                String   @id @default(cuid())
  code              String   @unique // streak_7, xp_100, lessons_10, etc
  name              String
  nameTranslations  Json     // { tg, ru, en, uz }
  emoji             String
  description       String
  descriptionTranslations Json
  rarity            String   // common | rare | epic | legendary
  conditionType     String   // streak | xp | lessons | premium
  conditionValue    Int
  xpReward          Int      @default(0)
  gemsReward        Int      @default(0)
  
  userAchievements  UserAchievement[]
}

model UserAchievement {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  achievementId     String
  achievement       Achievement @relation(fields: [achievementId], references: [id])
  earnedAt          DateTime @default(now())
  
  @@unique([userId, achievementId])
  @@index([userId])
}

model Subscription {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  plan              String   // monthly | yearly | lifetime
  status            String   // active | cancelled | expired | trial | grace_period
  
  // Google Play
  googlePurchaseToken String? @unique
  googleOrderId       String?
  googleProductId     String  // vip_monthly, vip_yearly, ramz_lifetime
  
  startedAt         DateTime @default(now())
  expiresAt         DateTime?
  cancelledAt       DateTime?
  autoRenew         Boolean  @default(true)
  
  @@index([userId, status])
  @@index([googlePurchaseToken])
}

model Payment {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  amount            Float
  currency          String   @default("USD")
  plan              String
  status            String   // pending | success | failed | refunded
  
  // Google Play
  googleOrderId     String?  @unique
  googlePurchaseToken String?
  
  createdAt         DateTime @default(now())
  
  @@index([userId])
}

model GemTransaction {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  amount            Int      // positive = earned, negative = spent
  reason            String   // lesson_complete, streak_freeze, heart_refill, etc
  createdAt         DateTime @default(now())
  
  @@index([userId])
}

model DailyTask {
  id                String   @id @default(cuid())
  userId            String
  taskType          String   // learn_words, complete_lesson, practice_time
  targetValue       Int
  currentValue      Int      @default(0)
  reward            Int      // gems
  date              String   // YYYY-MM-DD
  completed         Boolean  @default(false)

  @@unique([userId, date, taskType])
  @@index([userId, date])
}

// Per-day XP log — drives the weekly activity chart and analytics.
// One row per user per day; `source` is a JSON breakdown by XP type.
model DailyXp {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  date              DateTime @db.Date
  xp                Int      @default(0)
  source            Json?    // { lesson: 60, perfect: 20, achievement: 50, ... }

  @@unique([userId, date])
  @@index([userId, date])
}

// ─────────────────────────────────────────────────────────────────────────────
// Freemium subscription system
// ─────────────────────────────────────────────────────────────────────────────

/// Gateway-agnostic transaction log: subscriptions, gem packs, trials.
/// Canonical record for Alif Mobi / DC Pay / Stripe / Apple / Google / mock.
model PaymentTransaction {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  type         String   // subscription | gems | trial
  provider     String   // alif | dcpay | stripe | apple | google | mock
  amount       Float    // currency major units (e.g. 4.99)
  currency     String   @default("USD")
  status       String   @default("pending") // pending | success | failed | refunded
  plan         String?  // monthly | yearly (subscription)
  gemsAmount   Int?     // gems credited (gem purchases)
  promoCodeId  String?  // applied promo, if any
  externalId   String?  // gateway transaction / order id
  metadata     Json?    // raw gateway payload, A/B variant, trigger, etc.
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([provider])
  @@index([externalId])
}

/// Reusable discount / trial-extension codes.
model PromoCode {
  id              String   @id @default(cuid())
  code            String   @unique
  description     String?
  discountType    String   // percent | fixed | trial_days
  discountValue   Int      // percent 0-100 | cents | days
  appliesTo       String   @default("both") // monthly | yearly | both | gems
  maxRedemptions  Int?     // null = unlimited
  timesRedeemed   Int      @default(0)
  perUserLimit    Int      @default(1)
  startsAt        DateTime?
  expiresAt       DateTime?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  redemptions     PromoRedemption[]

  @@index([code])
  @@index([isActive])
}

/// One row per (promo, user) redemption — enforces perUserLimit + analytics.
model PromoRedemption {
  id           String    @id @default(cuid())
  promoCodeId  String
  promoCode    PromoCode @relation(fields: [promoCodeId], references: [id])
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  redeemedAt   DateTime  @default(now())

  @@unique([promoCodeId, userId])
  @@index([userId])
}

/// Paywall impressions + outcomes. Powers frequency-capping (so we stay
/// non-aggressive) and the Phase 7 conversion funnel.
model PaywallEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  trigger   String   // streak_at_risk | lives_empty | lesson_5 | level_locked | league_promoted | weekly_recap | inactive_14d | manual
  action    String   @default("shown") // shown | dismissed | started_trial | purchased
  variant   String?  // A/B variant label
  context   Json?    // user segment, offer shown, etc.
  createdAt DateTime @default(now())

  @@index([userId, trigger])
  @@index([trigger, action])
  @@index([createdAt])
}
