generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String
  name              String
  avatarUrl         String?
  nativeLang        String    @default("tg")
  interfaceLang     String    @default("tg")
  
  // Stats
  totalXp           Int       @default(0)
  weeklyXp          Int       @default(0)
  gems              Int       @default(0)
  level             String    @default("A1")
  currentCourseId   String?
  
  // Hearts
  hearts            Int       @default(5)
  maxHearts         Int       @default(5)
  lastHeartRegen    DateTime  @default(now())
  
  // Streak
  streak            Int       @default(0)
  longestStreak     Int       @default(0)
  lastActiveDate    DateTime?
  streakFreezesAvailable Int  @default(1)
  streakFreezesUsed Int       @default(0)
  
  // Premium
  isPremium         Boolean   @default(false)
  premiumPlan       String?   // "monthly" | "yearly" | "lifetime"
  premiumStartedAt  DateTime?
  premiumExpiresAt  DateTime?
  trialUsed         Boolean   @default(false)
  trialStartedAt    DateTime?
  
  // AI Tutor
  aiConversationsToday Int    @default(0)
  aiConversationsResetAt DateTime @default(now())
  
  // Misc
  createdAt         DateTime  @default(now())
  lastActiveAt      DateTime  @default(now())
  
  // Relations
  progress          UserProgress[]
  achievements      UserAchievement[]
  subscriptions     Subscription[]
  payments          Payment[]
  gemTransactions   GemTransaction[]
  userLanguages     UserLanguage[]
  
  @@index([email])
  @@index([isPremium])
}

model Language {
  id                String   @id @default(cuid())
  code              String   @unique // en, ru, tr, etc
  name              String
  nativeName        String
  flag              String
  isActive          Boolean  @default(true)
  speakersCount     String?  // "1.5B"
  sortOrder         Int      @default(0)
  
  courses           Course[]
  userLanguages     UserLanguage[]
}

model UserLanguage {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  languageId        String
  language          Language @relation(fields: [languageId], references: [id])
  
  fromLang          String   // tg, ru, etc
  currentLevel      String   @default("A1")
  xp                Int      @default(0)
  streak            Int      @default(0)
  isCurrent         Boolean  @default(false)
  goal              String?  // travel, work, study, social, culture, tech
  startedAt         DateTime @default(now())
  
  @@unique([userId, languageId])
  @@index([userId])
}

model Course {
  id                String   @id @default(cuid())
  languageId        String
  language          Language @relation(fields: [languageId], references: [id])
  level             String   // A1, A2, B1, B2, C1
  title             String
  description       String?
  emoji             String
  color             String   // hex color
  sortOrder         Int      @default(0)
  isActive          Boolean  @default(true)
  
  units             Unit[]
}

model Unit {
  id                String   @id @default(cuid())
  courseId          String
  course            Course   @relation(fields: [courseId], references: [id])
  title             String
  description       String?
  emoji             String
  color             String
  sortOrder         Int      @default(0)
  isPremium         Boolean  @default(false) // requires Premium
  isBoss            Boolean  @default(false) // boss unit
  
  lessons           Lesson[]
}

model Lesson {
  id                String   @id @default(cuid())
  unitId            String
  unit              Unit     @relation(fields: [unitId], references: [id])
  title             String
  titleTranslations Json     // { tg: "...", ru: "...", en: "...", uz: "..." }
  emoji             String
  xpReward          Int      @default(60)
  estimatedMin      Int      @default(5)
  sortOrder         Int      @default(0)
  isPremium         Boolean  @default(false)
  isActive          Boolean  @default(true)
  
  words             LessonWord[]
  progress          UserProgress[]
}

model Word {
  id                String   @id @default(cuid())
  langFrom          String
  langTo            String
  word              String
  translation       String
  ipa               String?
  audioUrl          String?
  emoji             String?
  imageUrl          String?
  example           String?
  exampleTranslation String?
  difficulty        Int      @default(1) // 1-5
  
  lessons           LessonWord[]
  
  @@index([langFrom, langTo])
}

model LessonWord {
  id                String   @id @default(cuid())
  lessonId          String
  lesson            Lesson   @relation(fields: [lessonId], references: [id])
  wordId            String
  word              Word     @relation(fields: [wordId], references: [id])
  sortOrder         Int      @default(0)
  
  @@unique([lessonId, wordId])
}

model UserProgress {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  lessonId          String
  lesson            Lesson   @relation(fields: [lessonId], references: [id])
  isCompleted       Boolean  @default(false)
  accuracy          Int      @default(0) // percentage
  xpEarned          Int      @default(0)
  timeSpent         Int      @default(0) // seconds
  heartsLost        Int      @default(0)
  completedAt       DateTime?
  
  @@unique([userId, lessonId])
  @@index([userId])
}

model Achievement {
  id                String   @id @default(cuid())
  code              String   @unique // streak_7, xp_100, lessons_10, etc
  name              String
  nameTranslations  Json     // { tg, ru, en, uz }
  emoji             String
  description       String
  descriptionTranslations Json
  rarity            String   // common | rare | epic | legendary
  conditionType     String   // streak | xp | lessons | premium
  conditionValue    Int
  xpReward          Int      @default(0)
  gemsReward        Int      @default(0)
  
  userAchievements  UserAchievement[]
}

model UserAchievement {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  achievementId     String
  achievement       Achievement @relation(fields: [achievementId], references: [id])
  earnedAt          DateTime @default(now())
  
  @@unique([userId, achievementId])
  @@index([userId])
}

model Subscription {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  plan              String   // monthly | yearly | lifetime
  status            String   // active | cancelled | expired | trial | grace_period
  
  // Google Play
  googlePurchaseToken String? @unique
  googleOrderId       String?
  googleProductId     String  // ramz_monthly, ramz_yearly, ramz_lifetime
  
  startedAt         DateTime @default(now())
  expiresAt         DateTime?
  cancelledAt       DateTime?
  autoRenew         Boolean  @default(true)
  
  @@index([userId, status])
  @@index([googlePurchaseToken])
}

model Payment {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  amount            Float
  currency          String   @default("USD")
  plan              String
  status            String   // pending | success | failed | refunded
  
  // Google Play
  googleOrderId     String?  @unique
  googlePurchaseToken String?
  
  createdAt         DateTime @default(now())
  
  @@index([userId])
}

model GemTransaction {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  amount            Int      // positive = earned, negative = spent
  reason            String   // lesson_complete, streak_freeze, heart_refill, etc
  createdAt         DateTime @default(now())
  
  @@index([userId])
}

model DailyTask {
  id                String   @id @default(cuid())
  userId            String
  taskType          String   // learn_words, complete_lesson, practice_time
  targetValue       Int
  currentValue      Int      @default(0)
  reward            Int      // gems
  date              String   // YYYY-MM-DD
  completed         Boolean  @default(false)
  
  @@unique([userId, date, taskType])
  @@index([userId, date])
}
